{
  "name": "@landelatech/mpesa-node",
  "version": "1.2.4",
  "description": "Production-ready Node.js SDK for Safaricom M-Pesa Daraja APIs — fluent API, automatic OAuth, zero boilerplate.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://opensource.landelatech.com/mpesa-node",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "ci:check": "yarn lint && yarn format:check && yarn typecheck && yarn test && yarn build && yarn typecheck:public",
    "coverage": "vitest run --coverage",
    "docs:build": "astro build --root docs",
    "docs:dev": "astro dev --root docs",
    "docs:preview": "astro preview --root docs",
    "docs:check": "astro check --root docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:public": "tsc -p tsconfig.public-types.json --noEmit"
  },
  "keywords": [
    "mpesa",
    "safaricom",
    "daraja",
    "sdk",
    "node",
    "typescript",
    "payments",
    "kenya",
    "stk-push",
    "b2c",
    "c2b",
    "reversal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/landelatech/mpesa-node"
  },
  "bugs": {
    "url": "https://github.com/landelatech/mpesa-node/issues"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.37.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "astro": "^5.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {}
}
